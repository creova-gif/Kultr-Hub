# ── Server ────────────────────────────────────────────────────────────────────
# Required — the API server refuses to start without it.
PORT=3001
# "development" | "production". Also gates simulated-mode fallbacks (payments,
# SMS/OTP) off in production even when a provider isn't configured — see
# lib/simulation.ts. Always set this explicitly in a real deployment.
NODE_ENV=development
# pino log level: "trace" | "debug" | "info" | "warn" | "error" | "fatal".
# Defaults to "info" if unset.
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Railway, PlanetScale, etc.)
DATABASE_URL=postgresql://user:password@host:5432/kultr

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# ── Payments ──────────────────────────────────────────────────────────────────
# Paystack secret key — get from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# URL the API server is publicly accessible at (used for Paystack callback)
API_BASE_URL=http://localhost:3001

# Deep link scheme the mobile app handles (used after Paystack redirect)
APP_CALLBACK_URL=kultr://payment

# ── M-Pesa / Daraja API ───────────────────────────────────────────────────────
# Safaricom Daraja API — https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
# Optional — Daraja has no webhook signature scheme, so this is a shared
# secret of your own choosing. If set, embed it as a ?token=... query param
# on MPESA_CALLBACK_URL above (the exact URL you register with Safaricom);
# the callback handler ignores any request whose token doesn't match. Leave
# both blank to skip this check (the endpoint only ever logs — see the
# handler's own comment for why that's safe without it, for now).
MPESA_CALLBACK_TOKEN=
# "sandbox" or "production"
MPESA_ENVIRONMENT=sandbox

# ── MTN Mobile Money (MoMo) ───────────────────────────────────────────────────
# MTN MoMo Collections — https://momodeveloper.mtn.com
# Covers Ghana (GHS), Uganda (UGX), Rwanda (RWF), Côte d'Ivoire (XOF), etc.
# Leave blank to run in simulated mode.
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
# "sandbox" or "production"
MTN_MOMO_ENVIRONMENT=sandbox
# ISO currency for your target market, e.g. GHS, UGX, XOF (sandbox uses EUR)
MTN_MOMO_CURRENCY=EUR

# ── SMS / OTP (Africa's Talking) ──────────────────────────────────────────────
# Phone-based auth (OTP). Leave blank to run in simulated mode (code logged +
# returned as `devCode`). https://africastalking.com
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
# "sandbox" or "production"
AT_ENVIRONMENT=sandbox

# ── Stripe (diaspora card payments) ───────────────────────────────────────────
# Card payments for UK/US/Canada/Europe and any market whose local currency
# Paystack can't settle in. Leave blank to run in simulated mode.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── Selcom (Tanzania mobile money) ────────────────────────────────────────────
# M-Pesa Tanzania, Tigo Pesa, Airtel Money TZ via Selcom Pay — the only rail
# in this app that reaches TZS mobile money (Safaricom's Daraja API in
# MPESA_* above is Kenya-only). Leave blank to run in simulated mode.
# Verify against Selcom's sandbox docs before enabling in production — see
# the warning at the top of artifacts/api-server/src/lib/selcom.ts.
# https://developers.selcommobile.com
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR_ID=
# "sandbox" or "production"
SELCOM_ENVIRONMENT=sandbox

# ── FX rates (Open Exchange Rates) ────────────────────────────────────────────
# Live currency conversion. Leave blank to serve the static fallback table.
# https://openexchangerates.org
OPEN_EXCHANGE_RATES_APP_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank to allow all in dev).
# REQUIRED when NODE_ENV=production — the server refuses to start in
# production without it rather than silently falling back to "*".
# CORS_ORIGIN=https://kultr.io,https://app.kultr.io

# ── Payment reconciliation worker ─────────────────────────────────────────────
# scripts/reconcile-payments.ts sweeps pending M-Pesa/MoMo/Selcom payments that
# never got a client-side verify call. Both have sane defaults — set only to tune.
# Ignore payments younger than this (still likely to resolve on their own).
RECONCILE_MIN_AGE_MINUTES=10
# Give up on (mark failed) payments older than this.
RECONCILE_MAX_AGE_HOURS=24

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Redis connection string. Leave blank to rate-limit against an in-process
# memory store (fine for a single instance; doesn't survive restarts and
# isn't shared across instances behind a load balancer).
REDIS_URL=

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Leave blank to disable — both SDKs no-op without a DSN.
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=

# ── Mobile App ────────────────────────────────────────────────────────────────
# URL of the running API server (set in your Expo environment)
EXPO_PUBLIC_API_URL=http://localhost:3001

# Base URL used when generating event share links
EXPO_PUBLIC_SHARE_BASE_URL=https://kultr.io
